{
  "expo": {
    "name": "TagYa",
    "slug": "tagya",
    "description": "Editor de etiquetas para impressoras Niimbot — crie etiquetas com texto, QR code, código de barras, formas e ícones e imprima por Bluetooth.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "primaryColor": "#7c4dff",
    "updates": {
      "url": "https://u.expo.dev/7f756abd-b664-4ede-83cc-e2af5da10c60"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gabriel.tagya",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "O TagYa usa Bluetooth para conectar e imprimir na sua impressora Niimbot.",
        "NSBluetoothPeripheralUsageDescription": "O TagYa usa Bluetooth para imprimir na sua impressora Niimbot.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gabriel.tagya",
      "adaptiveIcon": {
        "backgroundColor": "#7c4dff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "TagYa",
      "shortName": "TagYa",
      "themeColor": "#7c4dff",
      "backgroundColor": "#f6f5fb",
      "display": "standalone",
      "lang": "pt-BR",
      "description": "Editor de etiquetas Niimbot"
    },
    "plugins": [
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "neverForLocation": true,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "O TagYa usa Bluetooth para conectar e imprimir na sua impressora Niimbot."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7f756abd-b664-4ede-83cc-e2af5da10c60"
      }
    },
    "owner": "gcamaras-organization"
  }
}
